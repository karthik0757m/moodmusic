# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-generate-random-string

# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/callback

# For production, use HTTPS:
# SPOTIFY_REDIRECT_URI=https://yourdomain.com/callback

# AI API Keys for Text-Based Mood Detection
# Choose ONE provider (the app will auto-detect which one you have)

# Option 1: OpenAI (ChatGPT) - Recommended
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Option 2: Google Gemini - Free tier available
# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option 3: Anthropic (Claude) - Most accurate
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
